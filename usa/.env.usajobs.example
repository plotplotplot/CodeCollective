# HistoricJoa is public and does not require API credentials.
# By default the refresh script fetches postings with close dates on or after today.

USAJOBS_MAX_PAGES=0
USAJOBS_ALL_POSTINGS=0

# Optional date filters
# USAJOBS_START_POSITION_OPEN_DATE=2026-01-01
# USAJOBS_END_POSITION_OPEN_DATE=2026-12-31
# USAJOBS_START_POSITION_CLOSE_DATE=2026-03-14
# USAJOBS_END_POSITION_CLOSE_DATE=2026-12-31

# Optional repeatable filters, separated by |
# USAJOBS_HIRING_AGENCY_CODES=VALA
# USAJOBS_HIRING_DEPARTMENT_CODES=VA
# USAJOBS_POSITION_SERIES=2210
# USAJOBS_ANNOUNCEMENT_NUMBERS=123-ABC
# USAJOBS_CONTROL_NUMBERS=825422600

# Search API sharded refresh settings
# USAJOBS_SEARCH_OUTPUT_PATH=/home/julian/Documents/CodeCollective/usa/data/usajobs.json
# USAJOBS_FRONTEND_OUTPUT_PATH=/home/julian/Documents/CodeCollective/usa/data/usajobs-lite.json
# USAJOBS_MAX_AGE_DAYS=7
# USAJOBS_FORCE_REFRESH=0
